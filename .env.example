# =============================================================================
# ENVIRONMENT
# =============================================================================
# Selects the config class: local | dev | staging | prod
ENVIRONMENT=local

# =============================================================================
# LLM API KEYS
# =============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# GOOGLE_API_KEY is accepted as an alias for GEMINI_API_KEY
# Optional: override the Gemini model used for context extraction
# GEMINI_CONTEXT_MODEL=gemini-2.5-flash

# =============================================================================
# WEB SCRAPING
# =============================================================================
RAPIDAPI_KEY=
RAPIDAPI_HOST=
# Optional: ScrapingBee alternative scraper
# SCRAPINGBEE_API_KEY=

# =============================================================================
# AWS / S3
# =============================================================================
# Standard AWS SDK names (used by boto3 / shopify-template-autopopulator)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_BUCKET_REGION=

# =============================================================================
# GCP / SECRET MANAGER
# =============================================================================
# Required when ENVIRONMENT=staging or ENVIRONMENT=prod
GCP_PROJECT_ID=

# GCP Secret Manager key names for MongoDB credentials (prod/staging only)
# MONGO_PASSWORD_SECRET=
# MONGO_IP_SECRET=
# MONGO_USERNAME=

# =============================================================================
# MONGODB
# =============================================================================
# Direct connection URI — used in local/dev; overrides Secret Manager in prod/staging
MONGO_CONNECTION_URI=mongodb://localhost:27017/
MONGO_DB_NAME=myapp_dev

# Section repository database (populated landing page sections)
SECTION_REPO_DATABASE=
SECTION_REPO_COLLECTION=
SECTION_REPO_METADATA_COLLECTION=

# =============================================================================
# REDIS (LangGraph node cache)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_DB=0
# REDIS_PASSWORD=

# =============================================================================
# NODE SERVER (HTML compilation)
# =============================================================================
# URL of the Node.js server used to compile HTML templates
NODE_SERVER_URL=http://localhost:3002

# =============================================================================
# OBSERVABILITY
# =============================================================================
# Optional Langfuse tracing endpoint
# LANGFUSE_HOST=https://cloud.langfuse.com

# Log level: DEBUG | INFO | WARNING | ERROR
# WWAI_AGENT_ORCHESTRATION_LOG_LEVEL=INFO

# Set to false to show INFO logs (suppressed by default)
# WWAI_AGENT_ORCHESTRATION_SUPPRESS_INFO_LOGS=true

# Set to true to enable performance timing logs
# WWAI_AGENT_ORCHESTRATION_PERF_LOGS_ENABLED=false

# Prompt tracing (writes prompts + responses to DB)
# WWAI_AGENT_ORCHESTRATION_ENABLE_PROMPT_TRACE=true
# WWAI_AGENT_ORCHESTRATION_PROMPT_TRACE_WRITE_TO_DB=true

# =============================================================================
# DEMO / EVAL SCRIPTS (optional convenience overrides)
# =============================================================================
# DEFAULT_BUSINESS_NAME=Your Business Name
# DEFAULT_BUSINESS_ID=your-business-id-here
